rules_version = '2';

// Direct-line message inbox.
// Philosophy: the public page may CREATE a well-formed message and nothing else.
// No reads, no updates, no deletes — the inbox is write-only from the outside.
// You read messages through the Firebase console or an authenticated admin tool.

service cloud.firestore {
  match /databases/{database}/documents {

    match /messages/{msgId} {
      allow read, update, delete: if false;

      allow create: if
        // exact field set — no extras smuggled in
        request.resource.data.keys().hasOnly(
          ['name', 'contact', 'message', 'ua', 'page', 'createdAt']
        )
        // required fields, typed and bounded
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 80
        && request.resource.data.message is string
        && request.resource.data.message.size() > 0
        && request.resource.data.message.size() <= 1200
        // optional contact: string or null
        && (request.resource.data.contact == null
            || (request.resource.data.contact is string
                && request.resource.data.contact.size() <= 120))
        // metadata bounds
        && request.resource.data.ua is string
        && request.resource.data.ua.size() <= 160
        && request.resource.data.page is string
        && request.resource.data.page.size() <= 300
        // server timestamp only — client can't forge times
        && request.resource.data.createdAt == request.time;
    }

    // default deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
